{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/create-bill",
      "dest": "/main.py"
    },
    {
      "src": "/login",
      "dest": "/main.py"
    },
    {
      "src": "/register",
      "dest": "/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
